{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/privacy",  "dest": "/privacy.html" },
    { "src": "/terms",    "dest": "/terms.html"   },
    { "src": "/(.*)",     "dest": "/index.html"   }
  ]
}
